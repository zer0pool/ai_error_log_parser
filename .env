# LangChain / LangGraph Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGCHAIN_PROJECT="Airflow-Log-Analyzer"

# LLM API Keys
GOOGLE_API_KEY="your_google_gemini_api_key_here"

# Vector DB Settings
INDEX_PATH="data/vector_index.bin"
METADATA_PATH="data/metadata.pkl"

# Job Manager Service API
JOB_MANAGER_BASE_URL="http://your-job-manager-host"
JOB_MANAGER_API_KEY="your_job_manager_api_key_here"
